{
  "name": "c4n-4nevercompany-os",
  "version": "0.0.1",
  "private": true,
  "description": "4neverCompany OS — packaged desktop workspace bundling Paperclip + Hermes Agent + BMAD Method. See docs/4neverCompany_OS_Brief.md.",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.15"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "bmad": "bmad-method",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm -r --filter './packages/*' --filter './apps/*' typecheck",
    "test": "pnpm -r --filter './packages/*' --filter './apps/*' test",
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' build",
    "rust:fmt": "cargo fmt --all -- --check",
    "rust:fmt:fix": "cargo fmt --all",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:test": "cargo test --workspace",
    "dev:desktop": "pnpm --filter @c4n/desktop tauri dev",
    "build:desktop": "pnpm --filter @c4n/desktop tauri build",
    "dev:wizard": "pnpm --filter @c4n/wizard tauri dev",
    "build:wizard": "pnpm --filter @c4n/wizard tauri build"
  },
  "devDependencies": {
    "bmad-method": "6.7.1",
    "typescript": "5.8.3",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.20.0",
    "prettier": "^3.4.2"
  }
}
