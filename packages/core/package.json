{
  "name": "@c4n/core",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Types + Zod schemas + Glossary constants + attribution copy. Upstream-agnostic — no Paperclip/Hermes/BMAD coupling.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./attribution": "./src/attribution.ts",
    "./glossary": "./src/glossary.ts",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "scripts": {
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "vitest": "^2.1.8"
  }
}
