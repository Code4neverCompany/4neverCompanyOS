{
  "name": "@c4n/memory-resolver",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Memory tier read resolver — searches four tiers in precedence order: persona memory → project vault → Hermes native → Supermemory. Per FR-32.",
  "main": "./src/index.ts",
