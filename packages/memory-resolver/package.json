  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@c4n/core": "workspace:*",
    "@c4n/vault-layout": "workspace:*",
    "@c4n/supermemory-client": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "vitest": "^2.1.8"
  }
}
