node_modules/
dist/
**/dist/
.DS_Store
Thumbs.db
*.log
npm-debug.log*

# Spike apps — exploratory throwaway code; reports are tracked in docs/
spikes/

# Rust build artifacts
target/
**/target/
Cargo.lock.bak

# Tauri build outputs
src-tauri/target/
src-tauri/gen/

# Mobile icon variants produced by `pnpm tauri icon`. The desktop bundle
# doesn't ship Android/iOS targets; these get regenerated on demand if a
# future story adds mobile bundling. (Story 1.17.)
apps/*/src-tauri/icons/android/
apps/*/src-tauri/icons/ios/

# Pre-built sidecar binaries (e.g. the persona-supervisor). Build artifacts
# regenerated on demand; never committed. (Story 1.17 sidecar work.)
apps/*/src-tauri/binaries/

# TypeScript incremental build cache
*.tsbuildinfo

# Desktop app vault directory (created at workspace root when app runs in dev mode)
# Per vault-layout spec, vault path is configured via wizard and stored in
# ~/.4nevercompanyos/config.toml — the on-disk vault at the workspace root
# is a dev-time artifact that should never be committed.
vault/
